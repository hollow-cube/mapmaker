vec4 getPixel(vec2 uv) {
    int x = int(mod(uv.x * 16.0, 16.0));
    int y = int(mod(uv.y * 16.0, 16.0));
    return texture[y * 16 + x];
}

void main() {
    float r = length(round(worldPos * 8.0) / 8.0) * 2.0;

    if (r >= 10.0) {
        discard;
    }

    vec4 modifierColor = vec4(
        0.4 + sin((GameTime * 24000) / 5.0) * 0.1,
        0.1,
        0.1,
        0.5 + smoothstep(4.0, 10.0, r) * 0.5
    );

    fragColor = getPixel(texCoord0) * modifierColor;
}
