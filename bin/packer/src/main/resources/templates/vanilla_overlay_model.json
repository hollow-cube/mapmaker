{
  "model": {
    "type": "minecraft:composite",
    "models": [
      {
        "type": "minecraft:model",
        "model": "mapmaker:item/empty"
      },
      {
        "type": "minecraft:select",
        "property": "minecraft:custom_model_data",
        "index": 0,
        "fallback": {
          "type": "minecraft:empty"
        },
        "cases": "$cases"
      },
      {
        "type": "minecraft:select",
        "property": "minecraft:display_context",
        "fallback": {
          "type": "minecraft:empty"
        },
        "cases": [
          {
            "when": ["gui"],
            "model": {
              "type": "minecraft:select",
              "property": "minecraft:custom_model_data",
              "index": 1,
              "fallback": {
                "type": "minecraft:empty"
              },
              "cases": "$overlays"
            }
          }
        ]
      }
    ]
  }
}