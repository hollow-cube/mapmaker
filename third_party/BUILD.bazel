load("@rules_java//java:defs.bzl", "java_library", "java_plugin")

package(default_visibility = ["//visibility:public"])

# Auto service

java_plugin(
    name = "auto_service_processor",
    processor_class = "com.google.auto.service.processor.AutoServiceProcessor",
    visibility = ["//visibility:private"],
    deps = [
        "@maven//:com_google_auto_service_auto_service",
        "@maven//:com_google_auto_service_auto_service_annotations",
    ],
)

java_library(
    name = "auto_service",
    exported_plugins = [":auto_service_processor"],
    tags = ["maven:compile_only"],
    exports = ["@maven//:com_google_auto_service_auto_service_annotations"],
)

# Aliases of dependency groups

alias(
    name = "minestom",
    actual = "@maven//:net_minestom_minestom_snapshots",
)

java_library(
    name = "helidon",
    exports = [
        "@maven//:io_helidon_health_helidon_health",
        "@maven//:io_helidon_logging_helidon_logging_slf4j",
        "@maven//:io_helidon_media_helidon_media_common",
        "@maven//:io_helidon_metrics_helidon_metrics_prometheus",
        "@maven//:io_helidon_webserver_helidon_webserver",
        "@maven//:org_eclipse_microprofile_health_microprofile_health_api",
    ],
)

java_library(
    name = "adventure_all",
    exports = [
        "@maven//:net_kyori_adventure_api",
        "@maven//:net_kyori_adventure_key",
        "@maven//:net_kyori_adventure_text_minimessage",
        "@maven//:net_kyori_adventure_text_serializer_gson",
        "@maven//:net_kyori_adventure_text_serializer_plain",
    ],
)

java_library(
    name = "spicedb",
    exports = [
        "@maven//:com_authzed_api_authzed",
        "@maven//:com_google_protobuf_protobuf_java",
        "@maven//:io_grpc_grpc_api",
        "@maven//:io_grpc_grpc_protobuf",
        "@maven//:io_grpc_grpc_stub",
    ],
)

exports_files(["genfile.bzl"])
