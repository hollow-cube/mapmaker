load("@contrib_rules_jvm//java:defs.bzl", "JUNIT5_DEPS", "java_test_suite")
load("@rules_java//java:defs.bzl", "java_library")

java_library(
    name = "terraform",
    srcs = glob(include = ["src/main/java/**/*.java"]),
    resources = glob(include = ["src/main/resources/**/*"]),
    visibility = ["//visibility:public"],
    deps = [
        "@maven//:dev_hollowcube_dataconverter",
        "//modules/command",
        "//modules/common",
        "//modules/core",  # TODO: This is a terrible dependency, but need the action bar stuff for debug stick.
        "//modules/compat",
        "//third_party:minestom",
        "//third_party:adventure_all",
        "@maven//:com_google_code_gson_gson",
        "@maven//:it_unimi_dsi_fastutil",
        "@maven//:net_kyori_adventure_api",
        "@maven//:net_kyori_adventure_nbt",
        "@maven//:net_kyori_adventure_text_serializer_gson",
    ],
)

java_binary(
    name = "snapshot_viewer",
    main_class = "net.hollowcube.test.snapshot.viewer.SnapshotViewerServer",
    runtime_deps = [
        "//modules/terraform/src/test/java/net/hollowcube/test/snapshot/viewer",
        "//modules/test",
    ],
)

java_binary(
    name = "demo_server",
    main_class = "net.hollowcube.terraform.demo.DemoServer",
    runtime_deps = [
        "//modules/terraform/src/test/java/net/hollowcube/terraform/demo",
        "//modules/test",
    ],
)

