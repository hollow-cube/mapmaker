<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.gui.play ?>
<component width="9" height="10" align="ttb" sprite="play_maps/collection/container">
    <text width="0" height="0" translationKey="" font="map_details_title2" shift="50" value="Map Collection"/>

    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton2/>
        <button id="info" translationKey="gui.map_collection.information"/>
        <text id="name" width="5" font="line_0" translationKey="gui.map_collection.name" centered="true"/>
    </box>

    <spacer/>

    <box width="9" height="3" align="ltr">
        <spacer/>
        <pagination id="paging" width="7" height="3" child="MapEntry" loader="centered"/>
    </box>

    <box width="9" align="ltr">
        <spacer width="2"/>
        <button id="back" width="1" translationKey="gui.generic.previous_page"/>
        <text id="page_number" width="3" height="1" translationKey="forced.input" font="line_5" centered="true"/>
        <button id="next" width="1" translationKey="gui.generic.next_page"/>
        <spacer width="2"/>
    </box>
</component>
