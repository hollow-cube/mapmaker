<?xml version="1.0" ?>
<component width="9" height="5" align="ttb" sprite="store/addons/container">
    <spacer width="9" height="1"/>

    <box width="9" height="1" align="ltr">
        <spacer/>

        <!-- Map Slots -->
        <switch id="map_slots_switch" width="1" height="1">
            <button id="buy_map_slot_3" width="1" height="1"
                    translationKey="gui.store.addons.map_slots_3"
                    sprite="store/addons/map_slot_icon"
                    backgroundSprite="store/addons/map_slot_locked_bg"/>
            <button id="buy_map_slot_4" width="1" height="1"
                    translationKey="gui.store.addons.map_slots_4"
                    sprite="store/addons/map_slot_icon"
                    backgroundSprite="store/addons/map_slot_locked_bg"/>
            <button id="buy_map_slot_5" width="1" height="1"
                    translationKey="gui.store.addons.map_slots_5"
                    sprite="store/addons/map_slot_icon"
                    backgroundSprite="store/addons/map_slot_locked_bg"/>
            <button id="map_slots_maxed" width="1" height="1"
                    translationKey="gui.store.addons.map_slots_maxed"
                    sprite="store/addons/map_slot_unlocked"/>
        </switch>

        <spacer/>

        <!-- Map Size -->
        <switch id="map_size_switch" width="1" height="1">
            <button id="buy_map_size_2" width="1" height="1"
                    translationKey="gui.store.addons.map_size_large"
                    sprite="store/addons/map_size_2_icon"
                    backgroundSprite="store/addons/map_size_2_locked_bg"/>
            <button id="buy_map_size_3" width="1" height="1"
                    translationKey="gui.store.addons.map_size_massive"
                    sprite="store/addons/map_size_3_icon"
                    backgroundSprite="store/addons/map_size_3_locked_bg"/>
            <button id="map_size_colossal" width="1" height="1"
                    translationKey="gui.store.addons.map_size_colossal"
                    sprite="store/addons/map_size_4_icon"
                    backgroundSprite="store/addons/map_size_4_locked_bg"/>
            <button id="map_size_maxed" width="1" height="1"
                    translationKey="gui.store.addons.map_size_maxed"
                    sprite="store/addons/map_size_4_unlocked"/>
        </switch>

        <spacer/>

        <!-- Boosts -->
        <button id="boosts" width="1" height="1"
                translationKey="gui.store.addons.boosts"
                sprite="store/addons/map_boost_icon"
                backgroundSprite="store/addons/map_boost_locked_bg"/>

        <spacer/>

        <!-- Build Tools -->
        <switch id="terraform_switch" width="1" height="1">
            <button id="terraform_advanced" width="1" height="1"
                    translationKey="gui.store.addons.terraform_advanced"
                    sprite="store/addons/build_tools_icon"/>
            <button id="terraform_maxed" width="1" height="1"
                    translationKey="gui.store.addons.terraform_maxed"
                    sprite="store/addons/build_tools_unlocked"/>
        </switch>

    </box>

    <box width="9" align="ltr">
        <spacer/>
        <switch id="map_slots_cost">
            <label translationKey="gui.store.addons.cost_50_cubits" sprite="store/addons/cost_50_cubits"/>
            <label translationKey="gui.store.addons.cost_100_cubits" sprite="store/addons/cost_100_cubits"/>
            <label translationKey="gui.store.addons.cost_150_cubits" sprite="store/addons/cost_150_cubits"/>
            <label translationKey="gui.store.addons.cost_maxed" sprite="store/addons/cost_maxed"/>
        </switch>
        <spacer/>
        <switch id="map_size_cost">
            <label translationKey="gui.store.addons.cost_50_cubits" sprite="store/addons/cost_50_cubits"/>
            <label translationKey="gui.store.addons.cost_100_cubits" sprite="store/addons/cost_100_cubits"/>
            <label translationKey="gui.store.addons.cost_150_cubits" sprite="store/addons/cost_150_cubits"/>
            <label translationKey="gui.store.addons.cost_maxed" sprite="store/addons/cost_maxed"/>
        </switch>
    </box>
</component>
