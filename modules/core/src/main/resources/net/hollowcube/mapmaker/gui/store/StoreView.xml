<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.gui.store ?>
<component width="9" height="10" align="ttb">
    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.store.information"/>
        <spacer width="5"/>
        <button id="coins_to_cubits" width="2" heigh="1"
                translationKey="gui.store.coins_to_cubits" sprite="minecraft:gold_nugget"/>
    </box>

    <switch id="tab_switch" width="9" height="5">
        <BuyCubitsView/>
        <BuyHypercubeView/>
        <BuyAddonsView/>
    </switch>

    <!-- Bottom switcher -->
    <box width="9" height="3" align="ltr">
        <button id="tab_id_cubits" width="3" height="3"
                translationKey="gui.store.tab_cubits" sprite="minecraft:pink_dye"/>
        <button id="tab_id_hypercube" width="3" height="3"
                translationKey="gui.store.tab_hypercube" sprite="minecraft:blue_dye"/>
        <button id="tab_id_addons" width="3" height="3"
                translationKey="gui.store.tab_addons" sprite="minecraft:tripwire_hook"/>
    </box>
</component>
