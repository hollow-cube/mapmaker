<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.gui.play ?>
<?import net.hollowcube.mapmaker.gui.play.simple ?>
<component width="9" height="10" align="ttb" sprite="list_maps/container">
    <text id="title" width="9" height="0" translationKey=""
          font="map_details_title" centered="true"/>

    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.play_maps.simple.information"/>
        <!-- TODO how to handle text written into the GUI? -->
        <spacer width="5"/>
        <button translationKey="gui.play_maps.simple.toggle_complex_mode"/>
        <button id="query" translationKey="gui.play_maps.search_by_name"
                sprite="play_maps/search/filter/search_by_name"/>
    </box>

    <!-- Map list -->
    <box width="9" height="5" align="ltr">
        <box height="5" align="ttb">
            <spacer/>
            <button id="prev_page" height="3"
                    translationKey="gui.generic.previous_page"
                    sprite="generic/left_big" spritePos="1"/>
            <spacer/>
        </box>

        <pagination id="paging" width="7" height="5" child="MapEntry"/>

        <box height="5" align="ttb">
            <spacer/>
            <button id="next_page" height="3"
                    translationKey="gui.generic.next_page"
                    sprite="generic/right_big" spritePos="1"/>
            <spacer/>
        </box>
    </box>
</component>
