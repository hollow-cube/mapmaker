<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<component width="9" height="10" align="ltr" sprite="report_map/container">
    <text id="title" width="0" height="0" translationKey=""
          font="map_details_title" shift="51"/>
    <box width="9" height="5" align="ttb">
        <!-- Top bar -->
        <box width="9" align="ltr">
            <BackButton/>
            <label translationKey="gui.report_map.information" sprite="generic/information"/>
            <text id="map_id_text" width="5" height="1" translationKey="gui.report_map.map_id"
                  sprite="generic/text_display_5" font="play_maps_page" centered="true"/>
            <button width="2" id="add_comment" translationKey="gui.report_map.add_comment"/>
        </box>

        <spacer/>

        <!-- Buttons -->
        <box width="9" height="1" align="ltr">
            <spacer width="2"/>

            <switch id="switch_cheated">
                <button id="reason_cheated_off" translationKey="gui.report_map.category.cheated.off"
                        sprite="report_map/cheating_icon" backgroundSprite="report_map/default_bg"/>
                <button id="reason_cheated_on" translationKey="gui.report_map.category.cheated.on"
                        sprite="report_map/cheating_icon" backgroundSprite="report_map/selected_bg"/>
            </switch>
            <switch id="switch_discrimination">
                <button id="reason_discrimination_off" translationKey="gui.report_map.category.discrimination.off"
                        sprite="report_map/hate_icon" backgroundSprite="report_map/default_bg"/>
                <button id="reason_discrimination_on" translationKey="gui.report_map.category.discrimination.on"
                        sprite="report_map/hate_icon" backgroundSprite="report_map/selected_bg"/>
            </switch>
            <switch id="switch_explicit_content">
                <button id="reason_explicit_content_off" translationKey="gui.report_map.category.explicit_content.off"
                        sprite="report_map/sex_icon" backgroundSprite="report_map/default_bg"/>
                <button id="reason_explicit_content_on" translationKey="gui.report_map.category.explicit_content.on"
                        sprite="report_map/sex_icon" backgroundSprite="report_map/selected_bg"/>
            </switch>
            <switch id="switch_spam">
                <button id="reason_spam_off" translationKey="gui.report_map.category.spam.off"
                        sprite="report_map/spam_icon" backgroundSprite="report_map/default_bg"/>
                <button id="reason_spam_on" translationKey="gui.report_map.category.spam.on"
                        sprite="report_map/spam_icon" backgroundSprite="report_map/selected_bg"/>
            </switch>
            <switch id="switch_dmca">
                <button id="reason_dmca_off" translationKey="gui.report_map.category.dcma.off"
                        sprite="report_map/dmca_icon" backgroundSprite="report_map/default_bg"/>
                <button id="reason_dmca_on" translationKey="gui.report_map.category.dcma.on"
                        sprite="report_map/dmca_icon" backgroundSprite="report_map/selected_bg"/>
            </switch>
        </box>

        <spacer width="2"/>

        <box width="9" height="1" align="ltr">
            <spacer width="2"/>

            <switch id="submit_switch" width="5" height="1">
                <label id="submit_error" width="5" height="1" sprite="report_map/submit_report_error"
                       translationKey="gui.report_map.submit.missing_categories"/>
                <button id="submit" width="5" height="1" sprite="report_map/submit_report"
                        translationKey="gui.report_map.submit"/>
            </switch>
        </box>

    </box>
</component>
