<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.gui.store ?>
<component width="9" height="10" align="ttb" sprite="cosmetic/selector/container">
    <text id="title" width="0" height="0" translationKey=""
          font="map_details_title2" shift="58"/>
    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton2/>
        <label translationKey="gui.cosmetics.information" sprite="generic/information"/>
        <text id="tab_name_text" width="5" translationKey="gui.cosmetics.tab_name" font="slot_title"
              centered="true" sprite="generic/text_display_5"/>
        <label translationKey="gui.cosmetics.wardrobe"/>
        <switch id="show_locked_switch">
            <button id="show_locked_off" translationKey="gui.cosmetics.show_locked.off"
                    sprite="cosmetic/selector/big_lock_open" backgroundSprite="cosmetic/selector/big_lock_open_bg"/>
            <button id="show_locked_on" translationKey="gui.cosmetics.show_locked.on"
                    sprite="cosmetic/selector/big_lock_closed" backgroundSprite="cosmetic/selector/big_lock_closed_bg"/>
        </switch>
    </box>

    <box width="9" height="5" align="ltr">
        <spacer/>
        <pagination id="cosmetic_list" width="7" height="5" cached="true"
                    loader="centered" child="CosmeticEntry"/>
        <spacer/>
    </box>

    <!-- Bottom switcher -->
    <box width="9" height="1" align="ltr">
        <spacer/>
        <switch id="tab_hat_switch" width="1" height="1">
            <button id="tab_hat_off" width="1" height="1" translationKey="gui.cosmetics.tab.headwear.deselected"
                    backgroundSprite="cosmetic/tab/hats_unselected_bg" sprite="cosmetic/tab/hats_icon"/>
            <button id="tab_hat_on" width="1" height="1" translationKey="gui.cosmetics.tab.headwear.selected"
                    sprite="cosmetic/tab/hats_selected"/>
        </switch>
        <switch id="tab_backwear_switch" width="1" height="1">
            <button id="tab_backwear_off" width="1" height="1" translationKey="gui.cosmetics.tab.backwear.deselected"
                    backgroundSprite="cosmetic/tab/backwears_unselected_bg" sprite="cosmetic/tab/backwears_icon"/>
            <button id="tab_backwear_on" width="1" height="1" translationKey="gui.cosmetics.tab.backwear.selected"
                    sprite="cosmetic/tab/backwears_selected"/>
        </switch>
        <switch id="tab_accessory_switch" width="1" height="1">
            <button id="tab_accessory_off" width="1" height="1" translationKey="gui.cosmetics.tab.accessories.deselected"
                    backgroundSprite="cosmetic/tab/accessories_unselected_bg" sprite="cosmetic/tab/accessories_icon"/>
            <button id="tab_accessory_on" width="1" height="1" translationKey="gui.cosmetics.tab.accessories.selected"
                    sprite="cosmetic/tab/accessories_selected"/>
        </switch>
        <switch id="tab_pet_switch" width="1" height="1">
            <button id="tab_pet_off" width="1" height="1" translationKey="gui.cosmetics.tab.companions.deselected"
                    backgroundSprite="cosmetic/tab/pets_unselected_bg" sprite="cosmetic/tab/pets_icon"/>
            <button id="tab_pet_on" width="1" height="1" translationKey="gui.cosmetics.tab.companions.selected"
                    sprite="cosmetic/tab/pets_selected"/>
        </switch>
        <switch id="tab_emote_switch" width="1" height="1">
            <button id="tab_emote_off" width="1" height="1" translationKey="gui.cosmetics.tab.emotes.deselected"
                    backgroundSprite="cosmetic/tab/emotes_unselected_bg" sprite="cosmetic/tab/emotes_icon"/>
            <button id="tab_emote_on" width="1" height="1" translationKey="gui.cosmetics.tab.emotes.selected"
                    sprite="cosmetic/tab/emotes_selected"/>
        </switch>
        <switch id="tab_particle_switch" width="1" height="1">
            <button id="tab_particle_off" width="1" height="1" translationKey="gui.cosmetics.tab.particles.deselected"
                    backgroundSprite="cosmetic/tab/particles_unselected_bg" sprite="cosmetic/tab/particles_icon"/>
            <button id="tab_particle_on" width="1" height="1" translationKey="gui.cosmetics.tab.particles.selected"
                    sprite="cosmetic/tab/particles_selected"/>
        </switch>
        <switch id="tab_victory_effect_switch" width="1" height="1">
            <button id="tab_victory_effect_off" width="1" height="1" translationKey="gui.cosmetics.tab.victory_effects.deselected"
                    backgroundSprite="cosmetic/tab/victory_effects_unselected_bg"
                    sprite="cosmetic/tab/victory_effects_icon"/>
            <button id="tab_victory_effect_on" width="1" height="1" translationKey="gui.cosmetics.tab.victory_effects.selected"
                    sprite="cosmetic/tab/victory_effects_selected"/>
        </switch>
    </box>
</component>
