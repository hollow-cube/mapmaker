    text: "{\"extra\":[{\"color\":\"gray\",\"text\":\"ʙᴜʏɪɴɢ ᴛʜᴇ \"},{\"translate\":\"icon.hypercube\"},{\"color\":\"#FFDD4E\",\"text\":\"ʜʏᴘᴇʀᴄᴜʙᴇ \"},{\"color\":\"gray\",\"text\":\"ʀᴀɴᴋ ᴡɪʟʟ ɢɪᴠᴇ ʏᴏᴜ:\\n\\n- \"},{\"color\":\"#FFDD4E\",\"text\":\"ɢᴏʟᴅ \"},{\"color\":\"white\",\"text\":\"ɴᴀᴍᴇ ᴀɴᴅ ʙᴀᴅɢᴇ\"},\"\\n\",{\"color\":\"gray\",\"text\":\"- \"},{\"color\":\"white\",\"text\":\"ᴜᴘ ᴛᴏ \"},{\"color\":\"gold\",\"text\":\"600x600\"},{\"color\":\"white\",\"text\":\" ᴍᴀᴘ ѕɪᴢᴇ\"},\"\\n\",{\"color\":\"gray\",\"text\":\"- \"},{\"color\":\"green\",\"text\":\"3\"},{\"color\":\"white\",\"text\":\" ᴇxᴛʀᴀ ᴍᴀᴘ ѕʟᴏᴛѕ\"},\"\\n\",{\"color\":\"gray\",\"text\":\"- \"},{\"color\":\"aqua\",\"text\":\"ᴀʟʟ \"},{\"color\":\"white\",\"text\":\"ᴄᴜʀʀᴇɴᴛ ᴄᴏѕᴍᴇᴛɪᴄѕ\"},\"\\n\",{\"color\":\"gray\",\"text\":\"- \"},{\"color\":\"white\",\"text\":\"ᴇxᴛʀᴀ \"},{\"color\":\"light_purple\",\"text\":\"ᴇᴍᴏᴊɪѕ\"},\"\\n\",{\"color\":\"gray\",\"text\":\"-\"},\" ᴀᴄᴄᴇѕѕ ᴛᴏ ʙᴇᴛᴀ ᴛᴇѕᴛɪɴɢ\\n\",{\"color\":\"gray\",\"text\":\"& ᴍᴏʀᴇ!\"}],\"text\":\"\"}",
