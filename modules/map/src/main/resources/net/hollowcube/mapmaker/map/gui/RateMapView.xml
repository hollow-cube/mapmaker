<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<component width="9" height="10" align="ttb" sprite="rate_map/container">
    <text id="title" width="0" height="0" translationKey=""
          font="map_details_title" shift="55"/>
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.map_rating.information" sprite="generic/information"/>
        <text id="map_id_text" width="5" height="1" translationKey="gui.map_rating.map_id"
              font="play_maps_page" centered="true" sprite="generic/text_display_5"/>
        <button id="add_comment" translationKey="gui.map_rating.add_comment"
                sprite="rate_map/add_comment"/>
        <button id="report_map" translationKey="gui.map_rating.report_map"
                sprite="play_maps/details/report"/>
    </box>

    <spacer width="9" height="1"/>

    <box width="9" height="3" align="ltr">
        <spacer/>

        <switch id="like_switch" width="3" height="3">
            <button id="like_off" width="3" height="3" translationKey="gui.map_rating.like_off"
                    sprite="rate_map/like_off"/>
            <button id="like_on" width="3" height="3" translationKey="gui.map_rating.like_on"
                    sprite="rate_map/like_on"/>
        </switch>

        <spacer/>

        <switch id="dislike_switch" width="3" height="3">
            <button id="dislike_off" width="3" height="3" translationKey="gui.map_rating.dislike_off"
                    sprite="rate_map/dislike_off"/>
            <button id="dislike_on" width="3" height="3" translationKey="gui.map_rating.dislike_on"
                    sprite="rate_map/dislike_on"/>
        </switch>

    </box>
</component>