<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.map.gui.effect ?>
<component width="9" height="10" align="ttb" sprite="effect/status/container">
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.status.information"/>

        <text id="tab_text" width="5" height="1" translationKey="gui.status.tab"
              font="play_maps_page" centered="true"/>

        <button translationKey="gui.checkpoint.custom_blocks"
                sprite="effect/executor_menu"/>
        <button id="pick_up" translationKey="gui.status.pick_up"
                sprite="effect/pick_up"/>
    </box>

    <switch id="tab_switch" width="9" height="4">
        <StatusSettingsTab id="settings"/>
        <StatusActionsTab id="actions"/>
    </switch>

    <!-- Tab Buttons -->
    <box width="9" height="1" align="ltr">
        <spacer width="3"/>

        <switch id="tab_settings_state_switch">
            <button id="tab_settings" translationKey="gui.checkpoint.tab.settings"
                    sprite="effect/tab_settings_icon" backgroundSprite="effect/tab_settings_bg"/>
            <button id="tab_settings_set" translationKey="gui.checkpoint.tab.settings"
                    sprite="effect/tab_settings_selected"/>
        </switch>

        <spacer/>

        <switch id="tab_actions_state_switch">
            <button id="tab_actions" translationKey="gui.checkpoint.tab.actions"
                    sprite="effect/tab_actions_icon" backgroundSprite="effect/tab_actions_bg"/>
            <button id="tab_actions_set" translationKey="gui.checkpoint.tab.actions"
                    sprite="effect/tab_actions_selected"/>
        </switch>

    </box>
</component>