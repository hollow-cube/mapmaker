<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<component width="9" height="9" align="ttb">
    <box width="9" height="1" align="ltr">
        <BackButton/>
        <label translationKey="gui.biome_editor.information"/>
        <text id="gui_title" width="5" translationKey="gui.biome_editor.title" font="slot_title"
              centered="true"/>
        <button sprite="minecraft:barrier" translationKey="gui.biome_editor.copy"/>
        <button sprite="minecraft:barrier" translationKey="gui.biome_editor.delete"/>
    </box>

    <box width="9" height="1" align="ltr">
        <text id="biome_name" width="8" translationKey="gui.biome_editor.change_name"
              font="map_title" shift="19"/>
    </box>

    <spacer width="9" height="1" align="ltr">
    </spacer>

    <box width="9" height="1" align="ltr">
        <text width="3" height="1" id="sky_color"
              sprite="biome/color_bg_line_3"
              translationKey="gui.biome_editor.sky_color"
              font="line_3" centered="true"/>
        <text width="3" height="1" id="fog_color"
              sprite="biome/color_bg_line_3"
              translationKey="gui.biome_editor.fog_color"
              font="line_3" centered="true"/>
    </box>

    <box width="9" height="1" align="ltr">
        <text width="3" height="1" id="water_color"
              sprite="biome/color_bg_line_4"
              translationKey="gui.biome_editor.water_color"
              font="line_4" centered="true"/>
        <text width="3" height="1" id="water_fog_color"
              sprite="biome/color_bg_line_4"
              translationKey="gui.biome_editor.water_fog_color"
              font="line_4" centered="true"/>
    </box>

    <box width="9" height="1" align="ltr">
        <text width="3" height="1" id="grass_color"
              sprite="biome/color_bg_line_5"
              translationKey="gui.biome_editor.grass_color"
              font="line_5" centered="true"/>
        <text width="3" height="1" id="foliage_color"
              sprite="biome/color_bg_line_5"
              translationKey="gui.biome_editor.foliage_color"
              font="line_5" centered="true"/>
    </box>


</component>