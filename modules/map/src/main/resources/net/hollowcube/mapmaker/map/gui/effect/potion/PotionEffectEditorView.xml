<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.map.gui.effect.potion ?>
<component width="9" height="5" wipe_player_inv="true" align="ttb" sprite="effect/potion/potion_editor">
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.effect.potion.editor.information"/>

        <text id="header" width="5" translationKey="todo"
              font="line_0" centered="true"/>

        <spacer width="2"/>
    </box>

    <spacer/>

    <box width="9" height="1" align="ltr">
        <spacer width="2"/>

        <switch id="level_dec_switch">
            <button id="level_dec_off" translationKey="gui.effect.potion.level.dec_off"
                    sprite="effect/potion/modify_r1/disabled_minus"/>
            <button id="level_dec_on" translationKey="gui.effect.potion.level.dec_on"
                    sprite="effect/potion/modify_r1/one_minus"/>
        </switch>
        <text id="level" width="3" translationKey="gui.effect.potion.level.current"
              font="line_2" centered="true"/>
        <switch id="level_inc_switch">
            <button id="level_inc_off" translationKey="gui.effect.potion.level.inc_off"
                    sprite="effect/potion/modify_r1/disabled_plus"/>
            <button id="level_inc_on" translationKey="gui.effect.potion.level.inc_on"
                    sprite="effect/potion/modify_r1/one_plus"/>
        </switch>

    </box>

    <spacer/>

    <box width="9" height="1" align="ltr">
        <spacer/>

        <switch id="time_dec5_switch">
            <button id="time_dec5_off" translationKey="gui.effect.potion.time.dec5_off"
                    sprite="effect/potion/modify_r2/disabled_minus"/>
            <button id="time_dec5_on" translationKey="gui.effect.potion.time.dec5_on"
                    sprite="effect/potion/modify_r2/two_minus"/>
        </switch>
        <switch id="time_dec1_switch">
            <button id="time_dec1_off" translationKey="gui.effect.potion.time.dec1_off"
                    sprite="effect/potion/modify_r2/disabled_minus"/>
            <button id="time_dec1_on" translationKey="gui.effect.potion.time.dec1_on"
                    sprite="effect/potion/modify_r2/one_minus"/>
        </switch>

        <text id="time" width="3" translationKey="gui.effect.potion.level.current"
              font="line_4" centered="true"/>

        <switch id="time_inc1_switch">
            <button id="time_inc1_off" translationKey="gui.effect.potion.time.inc1_off"
                    sprite="effect/potion/modify_r2/disabled_plus"/>
            <button id="time_inc1_on" translationKey="gui.effect.potion.time.inc1_on"
                    sprite="effect/potion/modify_r2/one_plus"/>
        </switch>
        <switch id="time_inc5_switch">
            <button id="time_inc5_off" translationKey="gui.effect.potion.time.inc5_off"
                    sprite="effect/potion/modify_r2/disabled_plus"/>
            <button id="time_inc5_on" translationKey="gui.effect.potion.time.inc5_on"
                    sprite="effect/potion/modify_r2/two_plus"/>
        </switch>
    </box>

</component>