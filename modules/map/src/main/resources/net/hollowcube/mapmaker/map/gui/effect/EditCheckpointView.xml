<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.map.gui.effect ?>
<component width="9" height="10" align="ttb" sprite="effect/container">
    <text id="title" width="0" height="0" translationKey=""
          font="map_details_title2" shift="43"/>
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton2/>
        <label translationKey="gui.checkpoint.information" sprite="generic/information"/>

        <text id="tab_text" width="5" height="1" translationKey="gui.checkpoint.tab"
              sprite="generic/text_display_5" font="play_maps_page" centered="true"/>

        <label translationKey="gui.checkpoint.custom_blocks"/>
        <label translationKey="gui.checkpoint.pick_up"/>
    </box>

    <!-- Tab Buttons -->
    <box width="9" height="1" align="ltr">
        <switch id="tab_settings_state_switch" width="4">
            <button id="tab_settings" width="4" translationKey="gui.checkpoint.tab.settings.unselected"/>
            <button id="tab_settings_set" width="4" translationKey="gui.checkpoint.tab.settings.selected"
                    sprite="effect/settings/tab"/>
        </switch>

        <switch id="tab_switch_middle_slot">
            <button id="tab_middle_slot_settings" translationKey="gui.checkpoint.tab.settings.unselected"/>
            <button id="tab_middle_slot_actions" translationKey="gui.checkpoint.tab.actions.unselected"/>
        </switch>

        <switch id="tab_actions_state_switch" width="4">
            <button id="tab_actions" width="4" translationKey="gui.checkpoint.tab.actions.unselected"/>
            <button id="tab_actions_set" width="4" translationKey="gui.checkpoint.tab.actions.selected"
                    sprite="effect/actions/tab"/>
        </switch>
    </box>

    <switch id="tab_switch" width="9" height="4">
        <CheckpointSettingsTab id="settings"/>
        <CheckpointActionsTab id="actions"/>
    </switch>

</component>