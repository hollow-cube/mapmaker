<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.map.gui.buildermenu ?>
<component width="9" height="10" align="ttb" sprite="builder_menu/container">
    <text id="title" width="0" height="0" translationKey=""
          font="map_details_title2" shift="49"/>
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton2/>
        <label translationKey="gui.builder_menu.information" sprite="generic/information"/>
        <text id="tab_name" width="5" translationKey="gui.builder_menu.tab"
             sprite="generic/text_display_5" font="map_details_author" centered="true"/>
        <label translationKey="gui.builder_menu.invite_players"/>
        <button id="save_and_exit" translationKey="gui.builder_menu.save_and_exit" sprite="builder_menu/save_and_exit"/>
    </box>

    <box width="9" height="3" align="ttb">
        <box width="9" height="1" align="ltr">
            <switch id="tab_custom_blocks_switch" width="3" height="1">
                <button id="tab_custom_blocks_off" width="3" height="1" translationKey="gui.builder_menu.tab_custom_blocks.unselected"/>
                <button id="tab_custom_blocks_on" width="3" height="1" translationKey="gui.builder_menu.tab_custom_blocks.selected"
                        sprite="builder_menu/custom_blocks/tab"/>
            </switch>
            <switch id="tab_build_tools_switch" width="3" height="1">
                <button id="tab_build_tools_off" width="3" height="1" translationKey="gui.builder_menu.tab_build_tools.unselected"/>
                <button id="tab_build_tools_on" width="3" height="1" translationKey="gui.builder_menu.tab_build_tools.selected"
                        sprite="builder_menu/build_tools/tab"/>
            </switch>
            <switch id="tab_custom_items_switch" width="3" height="1">
                <button id="tab_custom_items_off" width="3" height="1" translationKey="gui.builder_menu.tab_custom_items.unselected"/>
                <button id="tab_custom_items_on" width="3" height="1" translationKey="gui.builder_menu.tab_custom_items.selected"
                        sprite="builder_menu/custom_items/tab"/>
            </switch>
        </box>
        <spacer/>
        <box width="9" height="1" align="ltr">
            <spacer width="1"/>
            <switch id="tab_content" width="7" height="1">
                <CustomBlocksView id="custom_blocks"/>
                <BuildToolsView id="build_tools"/>
                <CustomItemsView id="custom_items"/>
            </switch>
        </box>
    </box>

</component>