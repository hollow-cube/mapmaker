<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.map.gui.effect ?>
<component width="9" height="4" align="ttb" sprite="effect/actions/container">

    <box width="9" height="2" align="ltr">
        <switch id="potion_effects_switch" width="2" height="2">
            <button id="potion_effects_inactive" width="2" height="2"
                    translationKey="gui.effect.actions.potion_effects"
                    sprite="effect/actions/add_potions_inactive"/>
            <button id="potion_effects_active" width="2" height="2"
                    translationKey="gui.effect.actions.potion_effects"
                    sprite="effect/actions/add_potions_active"/>
        </switch>
        <switch id="clear_effects_switch" width="2" height="2">
            <button id="clear_effects_inactive" width="2" height="2"
                    translationKey="gui.effect.actions.clear_effects"
                    sprite="effect/actions/clear_potions_inactive"/>
            <button id="clear_effects_active" width="2" height="2"
                    translationKey="gui.effect.actions.clear_effects"
                    sprite="effect/actions/clear_potions_active"/>
        </switch>

        <spacer/>

        <switch id="teleport_switch" width="2" height="2">
            <button id="teleport_inactive" width="2" height="2"
                    translationKey="gui.effect.actions.teleport"
                    sprite="effect/actions/teleport_inactive"/>
            <button id="teleport_active" width="2" height="2"
                    translationKey="gui.effect.actions.teleport.data"
                    sprite="effect/actions/teleport_active"/>
        </switch>
        <switch id="settings_switch" width="2" height="2">
            <button id="settings_inactive" width="2" height="2"
                    translationKey="gui.effect.actions.settings"
                    sprite="effect/actions/toggle_map_settings_inactive"/>
            <button id="settings_active" width="2" height="2"
                    translationKey="gui.effect.actions.settings"
                    sprite="effect/actions/toggle_map_settings_active"/>
        </switch>
    </box>

    <box width="9" height="2" align="ltr">
        <switch id="add_item_switch" width="2" height="2">
            <button id="add_item_inactive" width="2" height="2"
                    translationKey="gui.effect.actions.add_item"
                    sprite="effect/actions/give_item_inactive"/>
            <button id="add_item_active" width="2" height="2"
                    translationKey="gui.effect.actions.add_item"
                    sprite="effect/actions/give_item_active"/>
        </switch>
    </box>

</component>