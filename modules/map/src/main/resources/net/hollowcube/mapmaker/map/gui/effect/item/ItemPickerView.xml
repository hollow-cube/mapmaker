                    backgroundSprite="effect/item/picker/bg_selected"/>
        </switch>
        <switch id="item_air_switch">
            <button id="item_air_off" translationKey="todo" sprite="effect/item/air"
                    backgroundSprite="effect/item/picker/bg_unselected"/>
            <button id="item_air_on" translationKey="todo" sprite="effect/item/air"
