<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<component width="9" height="10" align="ttb" sprite="effect/item/picker/container">
    <text id="title" width="0" height="0" translationKey=""
          font="map_details_title2" shift="49"/>
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton2/>
        <label translationKey="gui.effect.item.picker.information" sprite="generic/information"/>

        <text id="item_slot" width="5" translationKey="gui.effect.item.slot.current"
              font="slot_title" centered="true" sprite="generic/text_display_5"/>

        <button id="reset" width="2" translationKey="gui.effect.item.picker.reset" sprite="generic/2x1s/reset"/>
    </box>

    <spacer/>

    <box width="9" height="2" align="ltr">
        <spacer width="1"/>
        <switch id="item_firework_switch">
            <button id="item_firework_off" translationKey="gui.effect.item.firework_rocket.off" sprite="minecraft:firework_rocket"
                    backgroundSprite="effect/item/picker/bg_unselected"/>
            <button id="item_firework_on" translationKey="gui.effect.item.firework_rocket.on" sprite="minecraft:firework_rocket"
                    backgroundSprite="effect/item/picker/bg_selected"/>
        </switch>
        <switch id="item_trident_switch">
            <button id="item_trident_off" translationKey="gui.effect.item.trident.off" sprite="minecraft:trident"
                    backgroundSprite="effect/item/picker/bg_unselected"/>
            <button id="item_trident_on" translationKey="gui.effect.item.trident.on" sprite="minecraft:trident"
                    backgroundSprite="effect/item/picker/bg_selected"/>
        </switch>
        <switch id="item_air_switch">
            <button id="item_air_off" translationKey="gui.effect.item.remove.off" sprite="effect/item/air"
                    backgroundSprite="effect/item/picker/bg_unselected"/>
            <button id="item_air_on" translationKey="gui.effect.item.remove.on" sprite="effect/item/air"
                    backgroundSprite="effect/item/picker/bg_selected"/>
        </switch>
    </box>

</component>