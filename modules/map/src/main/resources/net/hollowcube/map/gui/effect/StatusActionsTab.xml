<?xml version="1.0" ?>
<?import net.hollowcube.map.gui.effect ?>
<component width="9" height="4" align="ttb" sprite="effect/status/actions">

    <box width="9" height="2" align="ltr">
        <switch id="potion_effects_switch" width="2" height="2">
            <button id="potion_effects_off" width="2" height="2"
                    translationKey="gui.effect.actions.potion_effects"
                    sprite="effect/actions/add_potions_off"/>
            <button id="potion_effects_on" width="2" height="2"
                    translationKey="gui.effect.actions.potion_effects"
                    sprite="effect/actions/add_potions_on"/>
        </switch>
        <switch id="clear_effects_switch" width="2" height="2">
            <button id="clear_effects_off" width="2" height="2"
                    translationKey="gui.effect.actions.clear_effects"
                    sprite="effect/actions/clear_potions_off"/>
            <button id="clear_effects_on" width="2" height="2"
                    translationKey="gui.effect.actions.clear_effects"
                    sprite="effect/actions/clear_potions_on"/>
        </switch>

        <spacer/>

        <switch id="teleport_switch" width="2" height="2">
            <button id="teleport_off" width="2" height="2"
                    translationKey="gui.effect.actions.teleport"
                    sprite="effect/actions/teleport_off"/>
            <button id="teleport_on" width="2" height="2"
                    translationKey="gui.effect.actions.teleport"
                    sprite="effect/actions/teleport_on"/>
        </switch>
        <button id="settings" width="2" height="2"
                translationKey="gui.effect.actions.settings"/>
    </box>

    <box width="9" height="2" align="ltr">
        <button id="add_item" width="2" height="2"
                translationKey="gui.effect.actions.add_item"/>
        <button id="remove_item" width="2" height="2"
                translationKey="gui.effect.actions.remove_item"/>

        <spacer/>

        <switch id="add_time_switch" width="2" height="2">
            <button id="add_time_off" width="2" height="2"
                    translationKey="gui.status.actions.add_time"
                    sprite="effect/status/extra_time_off"/>
            <button id="add_time_on" width="2" height="2"
                    translationKey="gui.status.actions.add_time"
                    sprite="effect/status/extra_time_on"/>
        </switch>
    </box>

</component>