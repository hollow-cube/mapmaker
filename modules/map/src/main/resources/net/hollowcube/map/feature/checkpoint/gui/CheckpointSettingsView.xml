<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.map.feature.checkpoint.gui ?>
<component width="9" height="6" align="ttb">
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.checkpoint.information"/>

        <label width="5" translationKey="gui.checkpoint.summary"
               sprite="minecraft:heavy_weighted_pressure_plate"/>

        <button translationKey="gui.checkpoint.executor"
                sprite="minecraft:nether_star"/>
        <button id="pick_up" translationKey="gui.checkpoint.pick_up"
                sprite="minecraft:minecart"/>
    </box>

    <!-- Middle bit -->
    <spacer width="9" height="3"/>

    <!-- Big Action Buttons -->
    <box width="9" height="2" align="ltr">
        <spacer width="6" height="2"/>

        <button id="reset_height" width="3" height="2" translationKey="gui.checkpoint.reset_height"
                sprite="minecraft:iron_boots"/>
    </box>
</component>