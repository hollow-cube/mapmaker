<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.map.gui.effect ?>
<component width="9" height="10" align="ttb">
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.status.information"/>

        <spacer width="5"/>

        <button translationKey="gui.status.executor"
                sprite="minecraft:nether_star"/>
        <button id="pick_up" translationKey="gui.status.pick_up"
                sprite="minecraft:minecart"/>
    </box>

    <switch id="tab_switch" width="9" height="4">
        <StatusSettingsTab id="settings"/>
        <StatusActionsTab id="actions"/>
    </switch>

    <spacer width="9" height="2"/>

    <!-- Tab Buttons -->
    <box width="9" height="1" align="ltr">
        <spacer width="2"/>

        <button id="tab_settings" translationKey="gui.status.tab_settings"
                sprite="minecraft:book"/>

        <spacer width="3"/>

        <button id="tab_actions" translationKey="gui.status.tab_actions"
                sprite="minecraft:detector_rail"/>

        <spacer width="2"/>
    </box>
</component>