<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.map.gui.effect.potion ?>
<component width="9" height="5" wipe_player_inv="true" align="ttb" sprite="effect/potion/potion_editor">
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.effect.potion.editor.information"/>

        <label id="header" width="5" translationKey="this.will.be.replaced" sprite="minecraft:potion"/>

        <spacer width="2"/>
    </box>

    <spacer/>

    <box width="9" height="1" align="ltr">
        <spacer width="2"/>

        <pagination id="entries" width="5" height="1" child="PotionEffectLevelEntry"/>
    </box>

    <spacer/>

    <box width="9" height="1" align="ltr">
        <spacer/>

        <button id="time_rem_5" translationKey="gui.effect.potion.time.rem_5"/>
        <button id="time_rem_1" translationKey="gui.effect.potion.time.rem_1"/>

        <button id="time_edit" width="3" translationKey="gui.effect.potion.time.current"
                sprite="minecraft:clock"/>

        <button id="time_add_1" translationKey="gui.effect.potion.time.add_1"/>
        <button id="time_add_5" translationKey="gui.effect.potion.time.add_5"/>
    </box>

</component>