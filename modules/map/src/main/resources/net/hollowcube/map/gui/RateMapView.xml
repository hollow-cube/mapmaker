<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<component width="9" height="10" align="ttb">
    <!-- Header -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.rate_map.information"/>

        <spacer width="5"/>

        <label width="2" translationKey="gui.rate_map.comment"
               sprite="minecraft:paper"/>
    </box>

    <spacer width="9" height="1"/>

    <box width="9" height="2" align="ltr">
        <spacer width="2"/>

        <switch id="like_switch" width="2" height="2">
            <button id="like_off" width="2" height="2" translationKey="gui.map_rating.like_off"
                    sprite="minecraft:lime_dye"/>
            <button id="like_on" width="2" height="2" translationKey="gui.map_rating.like_on"
                    sprite="minecraft:lime_dye"/>
        </switch>

        <spacer/>

        <switch id="dislike_switch" width="2" height="2">
            <button id="dislike_off" width="2" height="2" translationKey="gui.map_rating.dislike_off"
                    sprite="minecraft:red_dye"/>
            <button id="dislike_on" width="2" height="2" translationKey="gui.map_rating.dislike_on"
                    sprite="minecraft:red_dye"/>
        </switch>
        <spacer width="2"/>
    </box>
</component>