<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.hub.gui.org ?>
<component width="9" height="10" align="ttb" sprite="org_maps/container">
    <text id="title" width="9" height="0" translationKey=""
          font="map_details_title" centered="true"/>

    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.play_maps.simple.information"/>
        <text id="page_text" width="5" height="1" translationKey="gui.play_maps.page"
              font="play_maps_page" centered="true"/>
    </box>

    <!-- Org info -->
    <box width="9" height="2" align="ltr">

    </box>

    <!-- Map list -->
    <box width="9" height="3" align="ltr">
        <button id="prev_page" height="3"
                translationKey="gui.generic.previous_page"
                sprite="generic/left_big" spritePos="1"/>

        <pagination id="paging" width="7" height="3" cached="true"
                    loader="centered" child="OrgMapEntry"/>

        <button id="next_page" height="3"
                translationKey="gui.generic.next_page"
                sprite="generic/right_big" spritePos="1"/>
    </box>

    <OrgMapDetails id="details"/>

</component>
