<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.hub.gui.play ?>
<component width="9" height="10" align="ttb" sprite="play_maps/container">
    <!-- Top bar -->
    <box width="9" align="ltr">
        <label translationKey="gui.generic.back"/>
        <label translationKey="gui.play_maps.simple.information"/>
        <!-- TODO how to handle text written into the GUI? -->
        <spacer width="5"/>
        <button translationKey="gui.play_maps.simple.toggle_complex_mode"/>
        <button id="query" translationKey="gui.play_maps.search_by_name"/>
    </box>

    <!-- Map list -->
    <box width="9" height="5">
        <box height="5" align="ttb">
            <spacer/>
            <button height="3" translationKey="gui.generic.previous_page"/>
            <spacer/>
        </box>

        <pagination id="paging" width="7" height="5" child="MapEntry"/>

        <box height="5" align="ttb">
            <spacer/>
            <button height="3" translationKey="gui.generic.next_page"/>
            <spacer/>
        </box>
    </box>

    <!-- Controls -->
    <box width="9" height="3" align="ttb">
        <box width="9" height="2">
            <button id="parkour_toggle" width="3" height="2"
                    translationKey="gui.play_maps.simple.sorting_preset.parkour_maps"
                    sprite="play_maps/parkour_active"/>
            <button width="3" height="2" translationKey="gui.play_maps.simple.sorting_preset.building_showcases"/>
            <button width="3" height="2" translationKey="gui.play_maps.simple.sorting_preset.adventure_maps"/>
        </box>
        <box width="9" height="1">
            <spacer width="2"/>
            <button width="1" translationKey="gui.play_maps.simple.sorting_preset.all_time"/>
            <button width="1" translationKey="gui.play_maps.simple.sorting_preset.trending"/>
            <button width="1" translationKey="gui.play_maps.simple.sorting_preset.approved"/>
            <button width="1" translationKey="gui.play_maps.simple.sorting_preset.boosted"/>
            <button width="1" translationKey="gui.play_maps.simple.sorting_preset.new"/>
            <spacer width="2"/>
        </box>
    </box>
</component>
