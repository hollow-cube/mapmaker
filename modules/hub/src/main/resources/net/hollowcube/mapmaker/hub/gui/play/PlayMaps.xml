<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.hub.gui.play ?>
<component width="9" height="10" align="ttb" sprite="gui/play_maps/container">
    <!-- Top bar -->
    <box width="9" align="ltr">
        <label translationKey="gui.generic.back"/>
        <label translationKey="gui.play_maps.info"/>
        <!-- TODO how to handle text written into the GUI? -->
        <spacer width="5"/>
        <button translationKey="gui.play_maps.advanced_toggle"/>
        <button translationKey="gui.play_maps.search_name"/>
    </box>

    <!-- Map list -->
    <box width="9" height="5">
        <box height="5" align="ttb">
            <spacer/>
            <button height="3" translationKey="gui.generic.prev_page"/>
            <spacer/>
        </box>

        <pagination id="paging" width="7" height="5" child="MapEntry"/>

        <box height="5" align="ttb">
            <spacer/>
            <button height="3" translationKey="gui.generic.next_page"/>
            <spacer/>
        </box>
    </box>

    <!-- Controls -->
    <box width="9" height="3" align="ttb">
        <box width="9" height="2">
            <button id="parkour_toggle" width="3" height="2"
                    translationKey="gui.play_maps.basic.parkour"
                    sprite="gui/play_maps/parkour_active"/>
            <button width="3" height="2" translationKey="gui.play_maps.basic.building"/>
            <button width="3" height="2" translationKey="gui.play_maps.basic.adventure"/>
        </box>
        <box width="9" height="1">
            <spacer width="2"/>
            <button width="1" translationKey="gui.play_maps.basic.one"/>
            <button width="1" translationKey="gui.play_maps.basic.two"/>
            <button width="1" translationKey="gui.play_maps.basic.three"/>
            <button width="1" translationKey="gui.play_maps.basic.four"/>
            <button width="1" translationKey="gui.play_maps.basic.five"/>
            <spacer width="2"/>
        </box>
    </box>
</component>
