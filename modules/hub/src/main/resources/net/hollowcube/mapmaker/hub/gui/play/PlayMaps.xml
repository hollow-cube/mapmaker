<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<?import net.hollowcube.mapmaker.hub.gui.play ?>
<?import net.hollowcube.mapmaker.hub.gui.play.simple ?>
<component width="9" height="10" align="ttb" sprite="play_maps/search/container">
    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.play_maps.simple.information"/>
        <!-- TODO how to handle text written into the GUI? -->
        <spacer width="5"/>
        <button translationKey="gui.play_maps.simple.toggle_complex_mode"/>
        <Query/>
    </box>

    <!-- Map list -->
    <box width="9" height="5" align="ltr">
        <box height="5" align="ttb">
            <spacer/>
            <button id="prev_page" height="3"
                    translationKey="gui.generic.previous_page"
                    sprite="generic/left_big" spritePos="1"/>
            <spacer/>
        </box>

        <pagination id="paging" width="7" height="5"
                    loader="centered" child="MapEntry"/>

        <box height="5" align="ttb">
            <spacer/>
            <button id="next_page" height="3"
                    translationKey="gui.generic.next_page"
                    sprite="generic/right_big" spritePos="1"/>
            <spacer/>
        </box>
    </box>

    <!-- Controls -->
    <box width="9" height="3" align="ttb">
        <box width="9" height="2" align="ltr">
            <FilterParkourToggle id="parkour"/>
            <FilterBuildingToggle id="building"/>
            <button width="3" height="2"
                    translationKey="gui.play_maps.simple.sorting_preset.adventure"
                    sprite="play_maps/search/filter/adventure_off"/>
        </box>
        <box width="9" height="1" align="ltr">
            <spacer width="2"/>
            <SortBestToggle id="best"/>
            <SortTrendingToggle id="trending"/>
            <SortApprovedToggle id="approved"/>
            <SortBoostedToggle id="boosted"/>
            <SortRecentToggle id="recent"/>
            <spacer width="2"/>
        </box>
    </box>
</component>
