<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.hub.gui.common ?>
<?import net.hollowcube.mapmaker.hub.gui.play ?>
<component width="9" height="10" align="ttb">
    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton/>
        <label translationKey="gui.map_details.map_info_tab.information"/>
        <spacer/>
        <button width="3" translationKey="gui.map_details.creator_profile" sprite="player_head"/>
        <spacer/>
        <button translationKey="gui.map_details.map_info_tab.add_to_playlist"/>
        <button translationKey="gui.map_details.map_info_tab.report_map"/>
