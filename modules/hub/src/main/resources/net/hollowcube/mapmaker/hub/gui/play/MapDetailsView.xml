    <!-- Map list -->
    <spacer width="9" height="4"/>

    <!-- Controls -->
    <box width="9">
        <spacer/>
        <button translationKey="gui.map_details.map_info_tab"/>
        <spacer/>
        <button translationKey="gui.map_details.map_stats_tab"/>
