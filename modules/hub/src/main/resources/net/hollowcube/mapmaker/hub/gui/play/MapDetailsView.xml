<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.hub.gui.common ?>
<?import net.hollowcube.mapmaker.hub.gui.play ?>
<component width="9" height="10" align="ttb" sprite="gui/build_maps/details">
    <!-- Top bar -->
    <box width="9" align="ltr">
        <BackButton />
        <label translationKey="gui.map_details.info" />
        <spacer />
        <button width="3" translationKey="gui.map_details.creator" sprite="player_head" />
        <spacer />
        <button translationKey="gui.map_details.add_to_playlist" />
        <button translationKey="gui.map_details.report" />
    </box>

    <!-- Map list -->
    <spacer width="9" height="4" />

    <!-- Controls -->
    <box width="9">
        <spacer />
        <button translationKey="gui.map_details.tab.info" />
        <spacer />
        <button translationKey="gui.map_details.tab.stats" />
        <spacer />
        <button translationKey="gui.map_details.tab.times" />
        <spacer />
        <button translationKey="gui.map_details.tab.reviews" />
        <spacer />
    </box>

    <!-- More Controls -->
    <box width="9" height="3">
        <button width="3" height="3" translationKey="gui.map_details.boost" />
        <button id="play_map" width="3" height="2" translationKey="gui.map_details.play" />
        <button width="3" height="3" translationKey="gui.map_details.suggest" />
    </box>
