        <button translationKey="gui.map_details.map_reviews_tab"/>
        <spacer/>
    </box>

    <!-- More Controls -->
    <box width="9" height="3">
        <button width="3" height="3" translationKey="gui.map_details.map_info.boost_map"/>
        <button id="play_map" width="3" height="2" translationKey="gui.map_details.play_map"/>
        <button width="3" height="3" translationKey="gui.map_details.suggest_similar_maps"/>
