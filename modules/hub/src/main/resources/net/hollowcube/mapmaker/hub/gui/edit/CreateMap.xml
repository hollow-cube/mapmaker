<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.gui.common ?>
<component width="9" height="9" align="ttb" sprite="create_maps/create/container">
    <box width="9" height="1" align="ltr">
        <BackButton/>
        <label translationKey="gui.create_maps.new_map.information"/>
        <text id="slot_id_create" width="5" translationKey="gui.create_maps.new_map.title" font="slot_title"
              centered="true"/>
        <button width="2" translationKey="gui.create_maps.new_map.reset_to_default"/>
    </box>

    <spacer width="9" height="1"/>

    <box width="9" align="ltr">
        <spacer width="2"/>
        <label translationKey="gui.create_maps.new_map.generator"/>
        <button translationKey="gui.create_maps.new_map.generator.void"
                sprite="create_maps/create/generators/void_world_selected"/>
        <button translationKey="gui.create_maps.new_map.generator.flat"
                backgroundSprite="create_maps/create/generators/flat_world_bg"
                sprite="create_maps/create/generators/flat_world_icon"/>
        <button translationKey="gui.create_maps.new_map.generator.ocean"
                backgroundSprite="create_maps/create/generators/ocean_world_bg"
                sprite="create_maps/create/generators/ocean_world_icon"/>
        <button translationKey="gui.create_maps.new_map.more_options"
                backgroundSprite="create_maps/create/generators/and_more"/>
    </box>
    <box width="9" align="ltr">
        <spacer width="2"/>
        <label width="1" translationKey="gui.create_maps.new_map.size"/>
        <switch id="map_size_normal_switch">
            <button id="map_size_normal_unset"
                    translationKey="gui.create_maps.new_map.size.normal"
                    backgroundSprite="create_maps/create/sizes/normal_size_bg"
                    sprite="create_maps/create/sizes/normal_size_icon"/>
            <button id="map_size_normal_set"
                    translationKey="gui.create_maps.new_map.size.normal"
                    sprite="create_maps/create/sizes/normal_size_selected"/>
        </switch>
        <switch id="map_size_large_switch">
            <button id="map_size_large_unset"
                    translationKey="gui.create_maps.new_map.size.large"
                    backgroundSprite="create_maps/create/sizes/large_size_bg"
                    sprite="create_maps/create/sizes/large_size_icon"/>
            <button id="map_size_large_set"
                    translationKey="gui.create_maps.new_map.size.large"
                    sprite="create_maps/create/sizes/large_size_selected"/>
            <button id="map_size_large_locked"
                    translationKey="gui.create_maps.new_map.size.large.locked"
                    sprite="create_maps/create/sizes/large_size_locked"/>
        </switch>
        <switch id="map_size_massive_switch">
            <button id="map_size_massive_unset"
                    translationKey="gui.create_maps.new_map.size.massive"
                    backgroundSprite="create_maps/create/sizes/massive_size_bg"
                    sprite="create_maps/create/sizes/massive_size_icon"/>
            <button id="map_size_massive_set"
                    translationKey="gui.create_maps.new_map.size.massive"
                    sprite="create_maps/create/sizes/massive_size_selected"/>
            <button id="map_size_massive_locked"
                    translationKey="gui.create_maps.new_map.size.massive.locked"
                    sprite="create_maps/create/sizes/massive_size_locked"/>
        </switch>
        <button id="map_size_colossal_ignored"
                translationKey="gui.create_maps.new_map.size.colossal"
                sprite="create_maps/create/sizes/colossal_size_locked"/>
    </box>

    <spacer width="9" height="1"/>

    <box width="9" align="ltr">
        <spacer width="2"/>
        <button id="submit" width="5" translationKey="gui.create_maps.new_map.submit"/>
    </box>

    <box width="9" height="3" align="ltr">
        <spacer height="3"/>
        <spacer width="3" height="3" sprite="create_maps/big_button_closed"/>
        <spacer height="3"/>
        <spacer width="3" height="3" sprite="create_maps/big_button_closed"/>
        <spacer height="3"/>
    </box>

</component>