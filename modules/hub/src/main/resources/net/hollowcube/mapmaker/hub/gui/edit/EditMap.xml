<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.hub.gui.common ?>
<component width="9" height="9" align="ttb">
    <switch id="tab_switch" width="9" height="5">
        <!-- INFO TAB -->
        <box width="9" height="5" align="TTB">
            <box width="9" height="1" sprite="create_maps/tab_info/header">
                <BackButton/>
                <label translationKey="gui.create_maps.map_info_tab.information"/>
                <text id="slot_id" width="5" translationKey="gui.create_maps.map_slot" font="slot_title" centered="true" />
                <!--        todo those last 2 buttons-->
                <button translationKey="gui.create_maps.map_info_tab.manage_builders"
                        sprite="create_maps/tab_info/manage_builders"/>
                <button translationKey="gui.create_maps.map_info_tab.invite_players"
                        sprite="create_maps/tab_info/invite_players"/>
            </box>
            <box width="9" height="1">
                <!-- Shift by 19 to avoid the icon -->
                <text id="map_name" width="8" translationKey="gui.create_maps.map_info_tab.change_name"
                      font="map_title" shift="19"/>
                <switch id="set_map_icon_switch">
                    <button id="set_map_icon_unset" translationKey="gui.create_maps.map_info_tab.set_display_item.unset"
                            sprite="create_maps/tab_info/set_map_icon_unset"
                            backgroundSprite="create_maps/tab_info/set_map_icon_bg_unset"/>
                    <button id="set_map_icon_set" translationKey="gui.create_maps.map_info_tab.set_display_item.set"
                            sprite="create_maps/tab_info/set_map_icon_set"
                            backgroundSprite="create_maps/tab_info/set_map_icon_bg_set"/>
                </switch>
            </box>

            <box width="9">
                <button id="map_type_tab_parkour" width="3"
                        translationKey="gui.create_maps.map_info_tab.select_type.parkour"/>
                <button id="map_type_tab_building" width="3"
                        translationKey="gui.create_maps.map_info_tab.select_type.building"/>
                <button width="3" translationKey="gui.create_maps.map_info_tab.select_type.adventure"/>
            </box>
            <switch id="map_type_tab_switch" width="9" height="2">
                <!-- PARKOUR TAB -->
                <box width="9" height="2" sprite="create_maps/tab_info/tab_parkour/container">
                    <!-- These names MUST be synced with the ParkourSubVariant enum -->
                    <!-- todo this is super repetitive, might be worth looking into scripting it after all -->
                    <spacer width="1"/>
                    <switch id="parkour_subvariant_speedrun_switch">
                        <button id="parkour_subvariant_speedrun_unset"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.speedrun"
                                sprite="create_maps/tab_info/tab_parkour/sv_speedrun_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_speedrun_bg"/>
                        <button id="parkour_subvariant_speedrun_set"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.speedrun"
                                sprite="create_maps/tab_info/tab_parkour/sv_speedrun_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_speedrun_selected"/>
                    </switch>
                    <switch id="parkour_subvariant_sectioned_switch">
                        <button id="parkour_subvariant_sectioned_unset"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.sectioned"
                                sprite="create_maps/tab_info/tab_parkour/sv_sectioned_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_sectioned_bg"/>
                        <button id="parkour_subvariant_sectioned_set"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.sectioned"
                                sprite="create_maps/tab_info/tab_parkour/sv_sectioned_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_sectioned_selected"/>
                    </switch>
                    <switch id="parkour_subvariant_rankup_switch">
                        <button id="parkour_subvariant_rankup_unset"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.rankup"
                                sprite="create_maps/tab_info/tab_parkour/sv_rankup_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_rankup_bg"/>
                        <button id="parkour_subvariant_rankup_set"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.rankup"
                                sprite="create_maps/tab_info/tab_parkour/sv_rankup_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_rankup_selected"/>
                    </switch>
                    <switch id="parkour_subvariant_gauntlet_switch">
                        <button id="parkour_subvariant_gauntlet_unset"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.gauntlet"
                                sprite="create_maps/tab_info/tab_parkour/sv_gauntlet_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_gauntlet_bg"/>
                        <button id="parkour_subvariant_gauntlet_set"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.gauntlet"
                                sprite="create_maps/tab_info/tab_parkour/sv_gauntlet_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_gauntlet_selected"/>
                    </switch>
                    <switch id="parkour_subvariant_dropper_switch">
                        <button id="parkour_subvariant_dropper_unset"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.dropper"
                                sprite="create_maps/tab_info/tab_parkour/sv_dropper_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_dropper_bg"/>
                        <button id="parkour_subvariant_dropper_set"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.dropper"
                                sprite="create_maps/tab_info/tab_parkour/sv_dropper_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_dropper_selected"/>
                    </switch>
                    <switch id="parkour_subvariant_one_jump_switch">
                        <button id="parkour_subvariant_one_jump_unset"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.one_jump"
                                sprite="create_maps/tab_info/tab_parkour/sv_one_jump_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_one_jump_bg"/>
                        <button id="parkour_subvariant_one_jump_set"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.one_jump"
                                sprite="create_maps/tab_info/tab_parkour/sv_one_jump_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_one_jump_selected"/>
                    </switch>
                    <switch id="parkour_subvariant_informative_switch">
                        <button id="parkour_subvariant_informative_unset"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.informative"
                                sprite="create_maps/tab_info/tab_parkour/sv_informative_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_informative_bg"/>
                        <button id="parkour_subvariant_informative_set"
                                translationKey="gui.create_maps.map_info_tab.select_type.parkour.informative"
                                sprite="create_maps/tab_info/tab_parkour/sv_informative_icon"
                                backgroundSprite="create_maps/tab_info/tab_parkour/sv_informative_selected"/>
                    </switch>
                </box>

                <!-- BUILDING TAB -->
                <box width="9" height="2" sprite="create_maps/tab_info/tab_building/container">
                    <spacer width="1"/>
                    <button id="map_type_tab_building_showcase" width="1"
                            translationKey="gui.create_maps.map_info_tab.select_type.building.showcase"/>
                    <spacer width="1"/>
                    <button id="map_type_tab_building_tutorial" width="1"
                            translationKey="gui.create_maps.map_info_tab.select_type.building.tutorial"/>
                    <spacer width="1"/>
                    <button id="map_type_tab_building_educational" width="1"
                            translationKey="gui.create_maps.map_info_tab.select_type.building.educational"/>
                    <spacer width="1"/>
                    <button id="map_type_tab_building_map_pack" width="1"
                            translationKey="gui.create_maps.map_info_tab.select_type.building.map_pack"/>
                </box>
            </switch>
        </box>

        <!-- TAGS TAB -->
        <box width="9" height="5" sprite="create_maps/tab_tags/container">
            <box width="9" height="1">
                <BackButton/>
                <label translationKey="gui.create_maps.map_tags_tab.information"/>
                <text id="slot_id" width="5" translationKey="gui.create_maps.map_slot" font="slot_title" centered="true" />
            </box>

            <box width="9">
                <button width="4" id="map_tags_tab_visual"
                        translationKey="gui.map_details.map_tags_tab.visual_tag"/>
                <spacer width="1"/>
                <button width="4" id="map_tags_tab_gameplay"
                        translationKey="gui.map_details.map_tags_tab.gameplay_tag"/>
            </box>
            <switch id="map_tags_tab_switch" width="9" height="3">
                <!-- VISUAL TAB -->
                <box width="9" height="3" sprite="create_maps/tab_tags/tab_visual/container">
                    <!-- These names MUST be synced with the MapTags.java enum -->
                    <spacer width="1"/>
                    <switch id="map_tag_2d_switch">
                        <button id="map_tag_2d_unset"
                                translationKey="gui.create_maps.map_tags_tab.visual.2d"
                                sprite="create_maps/tab_tags/tab_visual/tag_2d_icon"
                                backgroundSprite="create_maps/tab_tags/tab_visual/tag_2d_bg"/>
                        <button id="map_tag_2d_set"
                                translationKey="gui.create_maps.map_tags_tab.visual.2d"
                                sprite="create_maps/tab_tags/tab_visual/tag_2d_icon"
                                backgroundSprite="create_maps/tab_tags/tab_visual/tag_2d_selected"/>
                    </switch>
                    <!-- TODO add rest of visual tags -->
                </box>
                <!-- GAMEPLAY TAB -->
                <box width="9" height="3" sprite="create_maps/tab_tags/tab_gameplay/container">
                    <!-- These names MUST be synced with MapTags.java enum -->
                    <spacer width="1"/>
                    <switch id="map_tag_autocomplete_switch">
                        <button id="map_tag_autocomplete_unset"
                                translationKey="gui.create_maps.map_tags_tab.gameplay.autocomplete"
                                sprite="create_maps/tab_tags/tab_gameplay/tag_autocomplete_icon"
                                backgroundSprite="create_maps/tab_tags/tab_gameplay/tag_autocomplete_bg"/>
                        <button id="map_tag_autocomplete_set"
                                translationKey="gui.create_maps.map_tags_tab.gameplay.autocomplete"
                                sprite="create_maps/tab_tags/tab_gameplay/tag_autocomplete_icon"
                                backgroundSprite="create_maps/tab_tags/tab_gameplay/tag_autocomplete_selected"/>
                    </switch>
                    <!-- TODO add rest of gameplay tags -->
                </box>
            </switch>
        </box>

        <!-- SETTINGS TAB -->
        <box width="9" height="5" sprite="create_maps/tab_settings/container">
            <box width="9" height="1">
                <BackButton/>
                <label translationKey="gui.create_maps.map_settings_tab.information"/>
            </box>
        </box>

        <!-- ACTIONS TAB -->
        <box width="9" height="5" sprite="create_maps/tab_actions/container" align="ttb">
            <box width="9" height="1">
                <BackButton/>
                <label translationKey="gui.create_maps.map_actions_tab.information"/>
                <label width="5" translationKey="gui.create_maps.map_slot"/>
                <!--        todo those last 2 buttons-->
                <button translationKey="gui.create_maps.map_actions_tab.map_backups"
                        sprite="create_maps/tab_actions/idk1"/>
                <button translationKey="gui.create_maps.map_actions_tab.submit_maps"
                        sprite="create_maps/tab_actions/idk2"/>
            </box>

            <box width="9" height="4" align="ltr">
                <spacer height="4"/>

                <box width="3" height="4" align="ttb">
                    <button width="3" height="2" translationKey="gui.create_maps.map_actions_tab.copy_map"/>
                    <button width="3" height="2" translationKey="gui.create_maps.map_actions_tab.transfer_ownership"/>
                </box>

                <spacer height="4"/>

                <box width="3" height="4" align="ttb">
                    <button width="3" height="2" translationKey="gui.create_maps.map_actions_tab.move_map"/>
                    <button id="delete_map" width="3" height="2" translationKey="gui.create_maps.map_actions_tab.delete_map"/>
                </box>

            </box>
        </box>
    </switch>

    <box width="9" align="ltr" sprite="create_maps/tab_container">
        <spacer/>
        <switch id="tab_info_switch">
            <button id="tab_info" translationKey="gui.create_maps.map_info_tab"
                    sprite="create_maps/tab_info/icon"
                    backgroundSprite="create_maps/tab_info/icon_bg_default"/>
            <button translationKey="gui.create_maps.map_info_tab"
                    sprite="create_maps/tab_info/icon_selected"/>
        </switch>
        <spacer/>
        <switch id="tab_tags_switch">
            <button id="tab_stats" translationKey="gui.create_maps.map_tags_tab"
                    sprite="create_maps/tab_tags/icon"
                    backgroundSprite="create_maps/tab_tags/icon_bg_default"/>
            <button translationKey="gui.create_maps.map_tags_tab"
                    sprite="create_maps/tab_tags/icon_selected"/>
        </switch>
        <spacer/>
        <switch id="tab_settings_switch">
            <button id="tab_settings" translationKey="gui.create_maps.map_settings_tab"
                    sprite="create_maps/tab_settings/icon"
                    backgroundSprite="create_maps/tab_settings/icon_bg_default"/>
            <button translationKey="gui.create_maps.map_settings_tab"
                    sprite="create_maps/tab_settings/icon_selected"/>
        </switch>
        <spacer/>
        <switch id="tab_actions_switch">
            <button id="tab_actions" translationKey="gui.create_maps.map_actions_tab"
                    sprite="create_maps/tab_actions/icon"
                    backgroundSprite="create_maps/tab_actions/icon_bg_default"/>
            <button translationKey="gui.create_maps.map_actions_tab"
                    sprite="create_maps/tab_actions/icon_selected"/>
        </switch>
        <spacer/>
    </box>

    <box width="9" height="3" align="ltr">
        <spacer height="3"/>
        <button id="edit_in_world" width="3" height="3" translationKey="gui.create_maps.build_map"
                sprite="create_maps/build"/>
        <spacer height="3"/>
        <switch id="publish_switch" width="3" height="3">
            <button width="3" height="3" translationKey="gui.create_maps.verify_error"
                    sprite="create_maps/verify_error"/>
            <button id="verify" width="3" height="3" translationKey="gui.create_maps.verify_map"
                    sprite="create_maps/verify"/>
            <button width="3" height="3" translationKey="gui.create_maps.can't_publish_map.no_name_and_no_display_item"
                    sprite="create_maps/publish_error"/>
            <button id="publish" width="3" height="3" translationKey="gui.create_maps.publish_map"
                    sprite="create_maps/publish"/>
        </switch>
        <spacer height="3"/>
    </box>

</component>