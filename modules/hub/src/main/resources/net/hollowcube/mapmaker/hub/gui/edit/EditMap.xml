<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.hub.gui.common ?>
<component width="9" height="9" align="ttb">

    <box width="9" height="1">
        <BackButton />
        <label translationKey="gui.create_maps.map_info_tab.information" />
        <label width="5" translationKey="todo" />
<!--        todo those last 2 buttons-->
        <button translationKey="gui.create_maps.map_info_tab.manage_builders" />
        <button translationKey="gui.create_maps.map_info_tab.invite_players" />
    </box>

    <switch id="tab_switch" width="9" height="4">
        <box width="9" height="4" sprite="create_maps/info/container">
            <box width="9" height="1">
                <!-- Shift by 19 to avoid the icon -->
                <text id="map_name" width="8" translationKey="gui.create_maps.map_info_tab.change_name"
                      font="map_title" shift="19" />
                <button translationKey="gui.create_maps.map_info_tab.set_display_item" />
            </box>

            <box width="9" height="1">
                <button id="" translationKey="todo.left" sprite="generic/left11" />
                <label width="7" translationKey="todo" sprite="create_maps/info/type_parkour" />
                <button id="" translationKey="todo.right" sprite="generic/right11" />
            </box>

            <spacer width="9" height="2" />
        </box>
        <spacer width="9" height="4"/>
        <spacer width="9" height="4"/>
        <spacer width="9" height="4"/>
    </switch>

    <box width="9" align="ltr">
        <spacer/>
        <button id="tab_info" translationKey="gui.create_maps.map_info_tab"/>
        <spacer/>
        <button id="tab_stats" translationKey="gui.create_maps.map_tags_tab" sprite="create_maps/stats"/>
        <spacer/>
        <button id="tab_settings" translationKey="gui.create_maps.map_settings_tab" sprite="create_maps/actions"/>
        <spacer/>
        <button id="tab_actions" translationKey="gui.create_maps.map_actions_tab" sprite="create_maps/settings"/>
        <spacer/>
    </box>

    <box width="9" height="3" align="ltr">
        <spacer height="3"/>
        <button id="edit_in_world" width="3" height="3" translationKey="gui.create_maps.build_map" sprite="create_maps/build" />
        <spacer height="3"/>
        <button id="publish" width="3" height="3" translationKey="gui.create_maps.publish_map" sprite="create_maps/publish" />
        <spacer height="3"/>
    </box>

</component>