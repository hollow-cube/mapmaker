<?xml version="1.0" ?>
<?import net.hollowcube.mapmaker.hub.gui.edit ?>
<component width="9" height="10" align="ttb" sprite="create_maps/container">

    <switch id="switch" width="9" height="9">
        <EditMap id="editor"/>
        <CreateMap id="creator"/>
        <CreateContestMap id="contest_creator"/>
    </switch>

    <box width="9" height="1" align="ltr">
        <EditMapIcon1 id="slot0"/>
        <EditMapIcon2 id="slot1"/>
        <EditMapIcon3 id="slot2"/>
        <EditMapIcon4 id="slot3"/>
        <EditMapIcon5 id="slot4"/>
        <switch id="contest_switch" width="4" height="1">
            <box width="4" height="1" align="ltr" sprite="create_maps/bottom_button_bg">
                <button id="personal_world" translationKey="gui.create_maps.personal_world"
                        sprite="create_maps/personal_world"/>
                <button id="folder" translationKey="gui.create_maps.map_folder"/>
                <button id="build_with_friends" translationKey="gui.create_maps.build_with_friends" width="2"/>
            </box>
            <button id="contest_slot_locked" translationKey="gui.create_maps.contest_slot.locked"
                    sprite="create_maps/contest_locked" width="4"/>
            <button id="contest_slot_create" translationKey="gui.create_maps.contest_slot.create"
                    sprite="create_maps/contest_available" width="4"/>
            <button id="contest_slot_in_progress" translationKey="gui.create_maps.contest_slot.in_progress"
                    sprite="create_maps/contest_available" width="4"/>
            <button id="contest_slot_submitted" translationKey="gui.create_maps.contest_slot.submitted"
                    sprite="create_maps/contest_submitted" width="4"/>
            <button id="contest_slot_completed" translationKey="gui.create_maps.contest_slot.completed"
                    sprite="create_maps/contest_locked" width="4"/>
        </switch>

    </box>

</component>